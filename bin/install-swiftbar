#!/bin/bash
# Installer for the SwiftBar menu bar dashboard that ships with the
# claude-code-caffeinate plugin. The Claude Code hooks themselves are wired
# automatically when the plugin is enabled; this script only handles the
# optional SwiftBar side (install app, create symlink, set plugin folder).
#
# Usage:
#   install-swiftbar               install + configure + launch (idempotent)
#   install-swiftbar --status      read-only diagnostic, no changes
#   install-swiftbar --uninstall   unset SwiftBar PluginDirectory pref + remove symlink
#   install-swiftbar --uninstall --remove-app
#                                  also uninstalls the SwiftBar cask
#   install-swiftbar --help
#
# Env overrides:
#   CLAUDE_PLUGIN_ROOT             Plugin root (set automatically by Claude Code).
#   CLAUDE_CAFFEINATE_PLUGIN_SRC   Override swiftbar/ directory location.
set -euo pipefail

# Resolve the plugin root. Priority:
#   1. CLAUDE_PLUGIN_ROOT (set by Claude Code when plugin is enabled)
#   2. CLAUDE_CAFFEINATE_PLUGIN_SRC (explicit override to swiftbar/ dir)
#   3. Derived from this script's location (bin/install-swiftbar → ../)
SELF="${BASH_SOURCE[0]}"
# Follow symlinks (may be in PATH via bin/ with symlinks to the real file).
while [ -L "$SELF" ]; do
  link=$(readlink "$SELF")
  case "$link" in
    /*) SELF="$link" ;;
    *)  SELF="$(cd "$(dirname "$SELF")" && pwd)/$link" ;;
  esac
done
SELF_DIR="$(cd "$(dirname "$SELF")" && pwd)"

if [ -n "${CLAUDE_CAFFEINATE_PLUGIN_SRC:-}" ]; then
  CLAUDE_PLUGIN_SRC="$CLAUDE_CAFFEINATE_PLUGIN_SRC"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -f "$CLAUDE_PLUGIN_ROOT/swiftbar/claude-activity.5s.sh" ]; then
  CLAUDE_PLUGIN_SRC="$CLAUDE_PLUGIN_ROOT/swiftbar"
elif [ -f "$SELF_DIR/../swiftbar/claude-activity.5s.sh" ]; then
  CLAUDE_PLUGIN_SRC="$(cd "$SELF_DIR/../swiftbar" && pwd)"
else
  echo "✗ Cannot locate claude-activity.5s.sh" >&2
  echo "  Set CLAUDE_CAFFEINATE_PLUGIN_SRC to the directory containing it." >&2
  exit 1
fi

PLUGIN_FILE="$CLAUDE_PLUGIN_SRC/claude-activity.5s.sh"

# SwiftBar's conventional community plugin location.
SWIFTBAR_PLUGINS_DIR="$HOME/Library/Application Support/SwiftBar/Plugins"
SWIFTBAR_PLUGIN_LINK="$SWIFTBAR_PLUGINS_DIR/claude-activity.5s.sh"

SWIFTBAR_DEFAULTS_DOMAIN="com.ameba.SwiftBar"
SWIFTBAR_APP_PATHS=(/Applications/SwiftBar.app "$HOME/Applications/SwiftBar.app")

mode="install"
remove_app=0
for arg in "$@"; do
  case "$arg" in
    --status)      mode="status" ;;
    --uninstall)   mode="uninstall" ;;
    --remove-app)  remove_app=1 ;;
    --help|-h)
      sed -n '2,15p' "$SELF" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *) echo "unknown arg: $arg" >&2; exit 2 ;;
  esac
done

ok()    { printf '  \033[32m✓\033[0m %s\n' "$*"; }
warn()  { printf '  \033[33m⚠\033[0m %s\n' "$*"; }
fail()  { printf '  \033[31m✗\033[0m %s\n' "$*"; }
info()  { printf '  • %s\n' "$*"; }
header(){ printf '\n\033[1m%s\033[0m\n' "$*"; }

swiftbar_app_path() {
  local p
  for p in "${SWIFTBAR_APP_PATHS[@]}"; do
    [ -d "$p" ] && { echo "$p"; return 0; }
  done
  return 1
}

check_macos() {
  [ "$(uname -s)" = "Darwin" ] || { fail "This installer is macOS-only (uname=$(uname -s))"; exit 1; }
  ok "macOS"
}

check_brew() {
  if command -v brew >/dev/null 2>&1; then
    ok "homebrew present ($(brew --version | head -1))"
    return 0
  fi
  fail "homebrew not found on PATH"
  info "Install it first:  /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
  return 1
}

check_jq_installed() { command -v jq >/dev/null 2>&1; }

check_swiftbar_installed() {
  swiftbar_app_path >/dev/null || brew list --cask swiftbar >/dev/null 2>&1
}

check_plugin_pref() {
  local cur
  cur=$(defaults read "$SWIFTBAR_DEFAULTS_DOMAIN" PluginDirectory 2>/dev/null || true)
  [ "$cur" = "$SWIFTBAR_PLUGINS_DIR" ]
}

check_symlink() {
  [ -L "$SWIFTBAR_PLUGIN_LINK" ] || return 1
  local target
  target=$(readlink "$SWIFTBAR_PLUGIN_LINK")
  [ "$target" = "$PLUGIN_FILE" ]
}

check_plugin_executable() { [ -x "$PLUGIN_FILE" ]; }

status_report() {
  header "System"
  check_macos

  header "Dependencies"
  check_brew || true
  if check_jq_installed; then ok "jq ($(jq --version))"; else fail "jq missing"; fi

  header "SwiftBar"
  if check_swiftbar_installed; then
    local path; path=$(swiftbar_app_path 2>/dev/null || echo "(installed via brew, app path unknown)")
    ok "SwiftBar installed at $path"
  else
    fail "SwiftBar not installed"
  fi
  if check_plugin_pref; then
    ok "PluginDirectory pref = $SWIFTBAR_PLUGINS_DIR"
  else
    local cur; cur=$(defaults read "$SWIFTBAR_DEFAULTS_DOMAIN" PluginDirectory 2>/dev/null || echo "(unset)")
    fail "PluginDirectory pref != $SWIFTBAR_PLUGINS_DIR (current: $cur)"
  fi
  if check_symlink; then
    ok "symlink $SWIFTBAR_PLUGIN_LINK → $PLUGIN_FILE"
  elif [ -e "$SWIFTBAR_PLUGIN_LINK" ]; then
    local t; t=$(readlink "$SWIFTBAR_PLUGIN_LINK" 2>/dev/null || echo "(regular file/dir)")
    fail "symlink wrong or missing (found: $t, want: $PLUGIN_FILE)"
  else
    fail "symlink missing at $SWIFTBAR_PLUGIN_LINK"
  fi
  if check_plugin_executable; then ok "plugin file executable ($PLUGIN_FILE)"; else fail "plugin file NOT executable: $PLUGIN_FILE"; fi
  if pgrep -x SwiftBar >/dev/null 2>&1; then ok "SwiftBar is running"; else warn "SwiftBar is not running"; fi

  header "Runtime state"
  local state_dir="${CLAUDE_STATE_DIR:-/tmp/claude-caffeinate}"
  if [ -d "$state_dir" ]; then
    local sessions active
    sessions=$(find "$state_dir/sessions" -name '*.json' -type f 2>/dev/null | wc -l | tr -d ' ')
    active=$(find "$state_dir/active" -type f 2>/dev/null | wc -l | tr -d ' ')
    ok "state dir ($state_dir) — $sessions sessions tracked, $active active"
  else
    info "no state dir yet ($state_dir); no Claude session has triggered a hook since boot"
  fi
}

do_install() {
  header "Installing claude-code-caffeinate SwiftBar dashboard"
  check_macos
  check_brew || exit 1

  if check_jq_installed; then
    ok "jq already installed"
  else
    info "Installing jq…"
    brew install jq
    ok "jq installed"
  fi

  if check_swiftbar_installed; then
    ok "SwiftBar already installed"
  else
    info "Installing SwiftBar (brew cask, ~30s first time)…"
    mkdir -p "$HOME/Applications"
    if brew install --cask --appdir="$HOME/Applications" swiftbar; then
      ok "SwiftBar installed to $HOME/Applications"
    else
      warn "User-scope install failed; falling back to /Applications (may prompt for sudo)"
      brew install --cask swiftbar
      ok "SwiftBar installed"
    fi
  fi

  prefs_changed=0
  if [ ! -d "$SWIFTBAR_PLUGINS_DIR" ]; then
    mkdir -p "$SWIFTBAR_PLUGINS_DIR"
    ok "created $SWIFTBAR_PLUGINS_DIR"
  else
    ok "conventional plugin dir exists: $SWIFTBAR_PLUGINS_DIR"
  fi

  if check_symlink; then
    ok "symlink already points to $PLUGIN_FILE"
  elif [ -L "$SWIFTBAR_PLUGIN_LINK" ]; then
    rm -f "$SWIFTBAR_PLUGIN_LINK"
    ln -s "$PLUGIN_FILE" "$SWIFTBAR_PLUGIN_LINK"
    ok "re-pointed symlink to $PLUGIN_FILE"
  elif [ -d "$SWIFTBAR_PLUGIN_LINK" ]; then
    if [ -z "$(ls -A "$SWIFTBAR_PLUGIN_LINK" 2>/dev/null)" ]; then
      rmdir "$SWIFTBAR_PLUGIN_LINK"
      ln -s "$PLUGIN_FILE" "$SWIFTBAR_PLUGIN_LINK"
      ok "cleared empty SwiftBar placeholder dir and created symlink"
    else
      fail "non-empty directory at $SWIFTBAR_PLUGIN_LINK — refusing to clobber"
      info "  inspect contents and remove manually, then re-run"
      exit 1
    fi
  elif [ -e "$SWIFTBAR_PLUGIN_LINK" ]; then
    fail "a regular file already exists at $SWIFTBAR_PLUGIN_LINK — refusing to clobber"
    info "  inspect and remove it manually, then re-run"
    exit 1
  else
    ln -s "$PLUGIN_FILE" "$SWIFTBAR_PLUGIN_LINK"
    ok "created symlink $SWIFTBAR_PLUGIN_LINK → $PLUGIN_FILE"
  fi

  if check_plugin_pref; then
    ok "PluginDirectory pref already set to $SWIFTBAR_PLUGINS_DIR"
  else
    defaults write "$SWIFTBAR_DEFAULTS_DOMAIN" PluginDirectory -string "$SWIFTBAR_PLUGINS_DIR"
    defaults write "$SWIFTBAR_DEFAULTS_DOMAIN" PluginDirectoryResolvedPath -string "$SWIFTBAR_PLUGINS_DIR"
    ok "PluginDirectory pref set to $SWIFTBAR_PLUGINS_DIR"
    warn "SwiftBar needs a user-granted security bookmark for this folder (one-time)."
    info "  Open SwiftBar Preferences → General → re-pick this folder."
    info "  In the file picker: Cmd+Shift+G lets you type the path directly."
    prefs_changed=1
  fi

  if check_plugin_executable; then
    ok "plugin file executable"
  else
    chmod +x "$PLUGIN_FILE"
    ok "plugin file made executable"
  fi

  if pgrep -x SwiftBar >/dev/null 2>&1; then
    if [ "$prefs_changed" -eq 1 ]; then
      osascript -e 'tell application "SwiftBar" to quit' 2>/dev/null || true
      sleep 0.3
      open -a SwiftBar
      ok "SwiftBar restarted (new preferences applied)"
    else
      ok "SwiftBar already running"
    fi
  else
    open -a SwiftBar
    ok "SwiftBar launched"
  fi

  echo
  ok "Done. Look for the ☕/moon icon in the menu bar (top-right)."
  info "To see live status:  install-swiftbar --status"
  info "To uninstall:        install-swiftbar --uninstall"
}

do_uninstall() {
  header "Uninstalling (SwiftBar pref + symlink + statusLine revert unless --remove-app)"
  check_macos

  # Revert the auto-wrapped statusLine, if we installed one
  local data_dir="${CLAUDE_PLUGIN_DATA:-$HOME/.local/state/claude-code-caffeinate}"
  local sline_marker="$data_dir/statusline-wrapped"
  local sline_backup="$data_dir/original-statusline-command"
  local settings="$HOME/.claude/settings.json"
  if [ -f "$sline_marker" ] && [ -f "$sline_backup" ] && [ -f "$settings" ] && command -v jq >/dev/null 2>&1; then
    local orig; orig=$(cat "$sline_backup")
    local tmp; tmp=$(mktemp)
    if jq --arg cmd "$orig" '.statusLine.command = $cmd' "$settings" > "$tmp"; then
      mv "$tmp" "$settings"
      rm -f "$sline_marker"
      ok "restored statusLine.command from backup"
      info "  refreshInterval left in place (harmless; delete it manually if undesired)"
    else
      rm -f "$tmp"
      warn "failed to restore statusLine; backup preserved at $sline_backup"
    fi
  fi

  if defaults read "$SWIFTBAR_DEFAULTS_DOMAIN" PluginDirectory >/dev/null 2>&1; then
    defaults delete "$SWIFTBAR_DEFAULTS_DOMAIN" PluginDirectory 2>/dev/null || true
    defaults delete "$SWIFTBAR_DEFAULTS_DOMAIN" PluginDirectoryResolvedPath 2>/dev/null || true
    ok "SwiftBar PluginDirectory preference removed"
  else
    info "PluginDirectory pref not set — nothing to clear"
  fi

  if [ -L "$SWIFTBAR_PLUGIN_LINK" ]; then
    rm -f "$SWIFTBAR_PLUGIN_LINK"
    ok "removed symlink $SWIFTBAR_PLUGIN_LINK"
  elif [ -e "$SWIFTBAR_PLUGIN_LINK" ]; then
    warn "a regular file exists at $SWIFTBAR_PLUGIN_LINK — not touching it"
  fi

  if [ "$remove_app" -eq 1 ]; then
    if check_swiftbar_installed; then
      if brew list --cask swiftbar >/dev/null 2>&1; then
        brew uninstall --cask swiftbar
        ok "SwiftBar cask uninstalled"
      else
        warn "SwiftBar present but not a brew cask — remove the .app manually"
      fi
    else
      info "SwiftBar already not installed"
    fi
  else
    info "Leaving SwiftBar.app in place (pass --remove-app to uninstall the cask)"
  fi
}

case "$mode" in
  status)    status_report ;;
  install)   do_install ;;
  uninstall) do_uninstall ;;
esac
